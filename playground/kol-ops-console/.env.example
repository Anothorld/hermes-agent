# Copy to .env and edit. Loaded automatically by start.sh.

# --- backend bind ---
KOC_HOST=0.0.0.0
KOC_PORT=8765

# --- auth ---
# Must be ≥16 chars. If unset, start.sh generates an ephemeral one per run.
KOC_JWT_SECRET=change-me-to-a-32-byte-random-string

# --- bridge (kol-ops-bridge plugin) ---
KOC_BRIDGE_BASE=http://127.0.0.1:8080/api/plugins/kol-ops-bridge
KOC_BRIDGE_KEY=replace-with-bridge-key
KOC_BRIDGE_TIMEOUT_SEC=60

# --- hermes gateway (for /campaigns/{id}/start) ---
KOC_GATEWAY_BASE=http://127.0.0.1:8642
KOC_GATEWAY_KEY=replace-with-gateway-key

# --- runtime env tag stored in CAL writes ---
KOC_ENV=LIVE
